# Copy to "webapp/.env.local". Never commit .env.local.
#
# Required (same names Railway uses — copy into Vercel Production env):
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=
MYSQLDATABASE=ProjectDB

# TLS: omitted for loopback (localhost / 127.0.0.1). Remote hosts (Railway proxy)
# use ssl: { rejectUnauthorized: false } by default. Force off for local MySQL
# that rejects SSL clients:
# MYSQL_SSL=false

# Optional: lower pool size on serverless (default 10)
# MYSQL_CONNECTION_LIMIT=5
