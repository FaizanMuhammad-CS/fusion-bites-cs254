# --- Local MySQL (typical) ---
# Copy to ".env.local" in this folder. Never commit .env.local.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ProjectDB

# Optional: force TLS for discrete host/port (often needed for cloud MySQL from Vercel)
# MYSQL_SSL=true

# Optional: lower pool size on serverless (default 10)
# MYSQL_CONNECTION_LIMIT=5

# --- Railway / hosted MySQL (recommended for Vercel) ---
# Option A: paste the full connection string from Railway (Variables tab).
# Often named MYSQL_URL, MYSQL_PUBLIC_URL, or DATABASE_URL.
# DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/ProjectDB
# MYSQL_URL=mysql://USER:PASSWORD@HOST:PORT/ProjectDB

# Option B: discrete variables (match what Railway exposes; names may vary — map in Vercel UI)
# MYSQL_HOST=containers-us-west-xxx.railway.app
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=...
# MYSQL_DATABASE=ProjectDB
# MYSQL_SSL=true
